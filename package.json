{
  "name": "oh-my-hermes-sisyphus",
  "version": "1.0.0",
  "description": "Multi-agent orchestration system for Hermes AI - Inspired by oh-my-claudecode",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "oh-my-hermes": "bridge/cli.cjs",
    "omh": "bridge/cli.cjs",
    "omh-cli": "bridge/cli.cjs"
  },
  "files": [
    "dist",
    "agents",
    "bridge",
    "bridge/mcp-server.cjs",
    "bridge/team-bridge.cjs",
    "bridge/team-mcp.cjs",
    "bridge/team.js",
    "bridge/cli.cjs",
    "bridge/runtime-cli.cjs",
    "commands",
    "hooks",
    "scripts",
    "skills",
    "templates",
    "docs",
    ".hermes-plugin",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && node scripts/build-skill-bridge.mjs && node scripts/build-mcp-server.mjs && node scripts/build-bridge-entry.mjs && npm run compose-docs && npm run build:runtime-cli && npm run build:team-server && npm run build:cli",
    "build:bridge": "node scripts/build-skill-bridge.mjs",
    "build:bridge-entry": "node scripts/build-bridge-entry.mjs",
    "build:cli": "node scripts/build-cli.mjs",
    "build:runtime-cli": "node scripts/build-runtime-cli.mjs",
    "build:team-server": "node scripts/build-team-server.mjs",
    "compose-docs": "node scripts/compose-docs.mjs",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest",
    "lint": "eslint src",
    "format": "prettier --write src/**/*.ts",
    "release": "tsx scripts/release.ts",
    "prepublishOnly": "npm run build && npm run compose-docs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "jsonc-parser": "^3.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.19.7",
    "esbuild": "^0.27.2",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.0.17"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shuangxipop1/oh-my-hermes.git"
  },
  "homepage": "https://github.com/shuangxipop1/oh-my-hermes#readme",
  "bugs": {
    "url": "https://github.com/shuangxipop1/oh-my-hermes/issues"
  },
  "author": "shuangxipop1",
  "license": "MIT",
  "keywords": [
    "hermes",
    "hermes-ai",
    "ai",
    "agent",
    "multi-agent",
    "orchestration",
    "omh",
    "anthropic"
  ],
  "publishConfig": {
    "access": "public"
  }
}
